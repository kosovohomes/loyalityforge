# Postgres connection string. For local dev you can run a free Postgres
# container: `docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres`
# then use: postgresql://postgres:postgres@localhost:5432/loyaltyforge
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Random secret used to sign NextAuth session JWTs. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# The canonical URL of your deployment. Vercel: your production domain.
# Local dev: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# --- Rate limiting (production) -------------------------------------------
# Upstash Redis REST credentials. When BOTH are set, rate-limit checks use
# Redis (works across serverless instances). When unset, falls back to an
# in-memory Map (per-instance — fine for dev, not for prod).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Number of trusted proxy layers between the client and your app. Vercel
# uses 1 (the edge layer). Self-hosted behind Nginx: 1. Behind an ALB +
# Nginx: 2. 0 = ignore x-forwarded-for, use x-real-ip.
TRUSTED_PROXY_HOPS="1"

# --- API key HMAC lookup hash (production) --------------------------------
# Optional. Secret used to derive the fast HMAC lookup hash for API keys.
# Falls back to NEXTAUTH_SECRET if unset.
# API_KEY_HMAC_SECRET=""
